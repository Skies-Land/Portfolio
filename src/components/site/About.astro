---
// ICÔNE
import { FiFileText } from "react-icons/fi";

// IMPORT DES DONNÉES DEPUIS LE MARKDOWN
import { frontmatter } from "../../data/About.md";

const about = frontmatter.about;
---

<section id="about" class="py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4">
        <div class="grid lg:grid-cols-12 gap-10">

            <!-- Titre et sous-titre -->
            <div class="lg:col-span-5">
                <p class="font-mono text-xs text-primary mb-4">// mon approche</p>
                <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-tight">
                    {about.title} <br />
                    <span class="text-muted-foreground">{about.subtitle}</span>
                </h2>
            </div>

            <!-- Description -->
            <div class="lg:col-span-7 space-y-7">
                {about.paragraphs.map((p: string) => (
                    <p class="text-muted-foreground leading-relaxed" set:html={p} />
                ))}

                <!-- Boutons CTA -->
                <div class="flex flex-wrap gap-3 pt-2">
                    <a
                        href={about.ctaPrimary.link}
                        class="inline-flex items-center justify-center rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity">
                        {about.ctaPrimary.label}
                    </a>
                    <a
                        href={about.ctaSecondary.link}
                        target="_blank"
                        rel="noreferrer noopener"
                        class="inline-flex items-center gap-2 rounded-lg border border-border bg-transparent px-5 py-2.5 text-sm font-medium text-foreground hover:bg-white/5 hover:border-primary/40 transition-colors">
                        <FiFileText size={15} />
                        {about.ctaSecondary.label}
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
