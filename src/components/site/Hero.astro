---
// ICÔNES
import { FaArrowDown } from "react-icons/fa";

// IMAGE
import { Image } from "astro:assets";
import IMG_Placeholder from "../../assets/images/IMG_Profil_Placeholder.webp";
---

<section id="home" class="relative pt-36 pb-24 sm:pt-44 sm:pb-32">
    <div class="mx-auto max-w-6xl px-4">
        <div class="grid lg:grid-cols-[1fr_auto] gap-12 items-center">
            <div class="space-y-7 max-w-3xl">

                <!-- Disponibilité -->
                <div class="inline-flex items-center gap-2 rounded-full border border-border/80 bg-surface/60 px-3 py-1 font-mono text-xs text-muted-foreground">
                    <span class="size-1.5 rounded-full bg-success animate-pulse"></span>
                    Disponible.
                </div>

                <!-- Titre -->
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05] text-gradient">
                    Concepteur Développeur Web <br />
                    <span class="text-muted-foreground">Front-End / Full-Stack</span>
                </h1>

                <!-- Description -->
                <p class="text-base sm:text-lg text-muted-foreground max-w-xl leading-relaxed">
                    Je conçois des architectures web modernes, robustes et centrées sur
                    l'expérience utilisateur. Mon focus : la performance, la lisibilité du
                    code et les meilleures pratiques d'ingénierie.
                </p>

                <!-- Technologies -->
                <div class="flex items-center gap-4 font-mono text-xs text-muted-foreground pt-2">
                    <span>React</span>
                    <span class="text-border">·</span>
                    <span>TypeScript</span>
                    <span class="text-border">·</span>
                    <span>Astro</span>
                </div>
            </div>

            <!-- Image de profil -->
            <div class="relative justify-self-center lg:justify-self-end">
                <div class="absolute -inset-4 rounded-3xl bg-linear-to-tr from-primary/30 via-transparent to-transparent blur-2xl"></div>
                <div class="relative size-56 sm:size-72 rounded-3xl overflow-hidden border border-white/10 surface-card">
                    <Image src={IMG_Placeholder} alt="Portrait de Jonathan, développeur web" width={800} height={1024} class="size-full object-cover" />
                </div>
            </div>
        </div>

        <!-- Elément visuelle animé pour inciter à scroller -->
        <a href="#about" class="mt-20 inline-flex items-center gap-2 font-mono text-xs text-muted-foreground hover:text-primary transition-colors group">
            <span class="size-8 rounded-full border border-border/80 grid place-items-center group-hover:border-primary/60 transition-colors">
                <FaArrowDown size={14} className="animate-bounce" />
            </span>
            Scroll pour explorer
        </a>
    </div>
</section>
