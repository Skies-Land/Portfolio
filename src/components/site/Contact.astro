---
// ICÔNES
import { FiGithub, FiCodepen, FiLinkedin, FiMail } from "react-icons/fi";

// COMPOSANT
import { ContactForm } from "../ui/ContactForm";

// IMPORT DES DONNÉES DEPUIS LE MARKDOWN
import { frontmatter } from "../../data/Socials.md";

const email = frontmatter.email;
const socials = frontmatter.socials;

// MAPPING DES ICÔNES
const iconMap: Record<string, any> = {
    Github: FiGithub,
    Codepen: FiCodepen,
    Linkedin: FiLinkedin
};
---

<section id="contact" class="py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4">
        <div class="grid lg:grid-cols-5 gap-10">
            <div class="lg:col-span-2 space-y-8">

                <!-- Titre et sous-titre -->
                <div>
                    <p class="font-mono text-xs text-primary mb-4">// me contacter</p>
                    <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight leading-tight">
                        Prêt à structurer votre prochain projet ?
                    </h2>
                    <p class="text-muted-foreground mt-4 leading-relaxed">
                        Laissez-moi un message, je vous répondrai avec intérêt.
                    </p>
                </div>

                <!-- Réseaux & Code -->
                <div class="surface-card rounded-2xl p-5 space-y-4">
                    <p class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">
                        Réseaux & Code
                    </p>
                    <div class="flex flex-col gap-3">
                        {socials.map((s: any) => {
                            const IconComponent = iconMap[s.icon];
                            return (
                                <a
                                    href={s.url}
                                    target="_blank"
                                    rel="noreferrer noopener"
                                    class="flex items-center gap-3 text-sm text-muted-foreground hover:text-primary transition-colors group"
                                >
                                    <span class="size-9 rounded-md border border-border/60 grid place-items-center group-hover:border-primary/40 transition-colors">
                                        <IconComponent size={15} />
                                    </span>
                                    {s.label}
                                </a>
                            );
                        })}
                        <a
                            href={`mailto:${email}`}
                            class="flex items-center gap-3 text-sm text-muted-foreground hover:text-primary transition-colors group"
                        >
                            <span class="size-9 rounded-md border border-border/60 grid place-items-center group-hover:border-primary/40 transition-colors">
                                <FiMail size={15} />
                            </span>
                            {email}
                        </a>
                    </div>
                </div>
            </div>

            <!-- Formulaire de contact -->
            <ContactForm client:visible />
        </div>
    </div>
</section>