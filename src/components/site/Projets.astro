---
// ICÔNE
import { FiArrowUpRight } from "react-icons/fi";

// IMPORT DES DONNÉES DEPUIS LE MARKDOWN
import { frontmatter } from "../../data/Projets.md";

// CLASSE POUR LA DISPOSITION DES PROJETS
const spanClass: Record<string, string> = {
    lg: "md:col-span-2",
    md: "md:col-span-1",
    sm: "md:col-span-1",
};

const projets = frontmatter.projets;
---

<section id="projets" class="py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4">
        <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">

            <!-- Section Titre -->
            <div>
                <p class="font-mono text-xs text-primary mb-4">// mes projets</p>
                <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
                    Sélection de projets
                </h2>
                <p class="text-muted-foreground mt-3 max-w-xl">
                    Des solutions techniques concrètes répondant à des besoins métiers.
                </p>
            </div>
            <span class="font-mono text-xs text-muted-foreground">
                {String(projets.length).padStart(2, "0")} projets
            </span>
        </div>

        <div class="grid md:grid-cols-3 gap-5">
            {projets.map((p: any) => (
                <a
                    href={`/projets/${p.id}`}
                    class={`group surface-card rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-glow ${spanClass[p.span]}`}
                >
                    <div class="aspect-16/10 overflow-hidden border-b border-white/5 bg-background">
                        <img
                            src={p.coverImage}
                            alt={p.title}
                            width={1280}
                            height={896}
                            loading="lazy"
                            class="size-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                        />
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="space-y-1">
                            {p.expertiseAngle && (
                                <p class="font-mono text-[10px] text-primary uppercase tracking-wider font-semibold">
                                    {p.expertiseAngle}
                                </p>
                            )}
                            <div class="flex items-start justify-between gap-4">
                                <h3 class="text-lg font-semibold tracking-tight">
                                    {p.title}
                                </h3>
                                <FiArrowUpRight
                                    size={18}
                                    className="text-muted-foreground group-hover:text-primary transition-colors shrink-0 mt-1"
                                />
                            </div>
                        </div>
                        <p class="text-sm text-muted-foreground leading-relaxed line-clamp-2">
                            {p.shortDescription}
                        </p>
                        <div class="flex flex-wrap gap-1.5 pt-1">
                            {p.tags.map((t: string) => (
                                <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded-md bg-white/4 border border-white/5 text-muted-foreground">
                                    {t}
                                </span>
                            ))}
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>