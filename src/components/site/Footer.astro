---
// ICÔNES
import { FaGithub, FaCodepen, FaLinkedin } from "react-icons/fa";

// IMPORT DES DONNÉES DEPUIS LE MARKDOWN
import { frontmatter as profileData } from "../../data/Profile.md";
import { frontmatter as socialsData } from "../../data/Socials.md";

const profile = profileData.profile;
const socials = socialsData.socials;

// MAPPING DES ICÔNES
const iconMap: Record<string, any> = {
    Github: FaGithub,
    Codepen: FaCodepen,
    Linkedin: FaLinkedin
};
---

<footer class="border-t border-border/60 mt-32">
  <div class="mx-auto max-w-6xl px-4 py-12 grid gap-8 md:grid-cols-3 items-start">

    <!-- Identité -->
    <div>
      <a href="/" class="font-mono text-sm">
        J.A. <span class="text-muted-foreground">/</span> Dev
      </a>
      <p class="text-sm text-muted-foreground mt-3 max-w-xs">
        {profile.footerDescription}
      </p>
    </div>

    <!-- Navigation -->
    <nav class="flex flex-col gap-2 text-sm">
      <a href="/#home" class="text-muted-foreground hover:text-foreground">
        Accueil
      </a>
      <a href="/#projets" class="text-muted-foreground hover:text-foreground">
        Projets
      </a>
      <a href="/#services" class="text-muted-foreground hover:text-foreground">
        Mes services
      </a>
    </nav>

    <!-- Réseaux -->
    <div class="flex md:justify-end gap-3">
      {socials.map((s: any) => {
        const IconComponent = iconMap[s.icon];
        return (
          <a
            href={s.url}
            target="_blank"
            rel="noreferrer noopener"
            aria-label={s.name}
            class="p-2 rounded-md border border-border/60 text-muted-foreground hover:text-primary hover:border-primary/40 transition-colors"
          >
            <IconComponent size={18} />
          </a>
        );
      })}
    </div>
  </div>

  <!-- copyright -->
  <div class="border-t border-border/60">
    <div class="mx-auto max-w-6xl px-4 py-5 text-xs font-mono text-muted-foreground flex flex-wrap justify-between gap-2">
      <span id="copyright-year">© Jonathan. Tous droits réservés.</span>
      <span class="text-[10px] opacity-75">Développé avec Astro · Tailwind CSS | Typographie Geist</span>
    </div>
  </div>

  <script>
    // Récupération de l'année en cours via JS Vanilla et injection dans le DOM
    const yearSpan = document.getElementById('copyright-year');
    if (yearSpan) {
      yearSpan.textContent = `© ${new Date().getFullYear()} Jonathan. Tous droits réservés.`;
    }
  </script>

</footer>
