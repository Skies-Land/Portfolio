---
// ICÔNES
import { FiCompass, FiShield, FiCode } from "react-icons/fi";

// IMPORT DES DONNÉES DEPUIS LE MARKDOWN
import { frontmatter } from "../../data/Services.md";

// MAPPING DES ICÔNES
const iconMap: Record<string, any> = {
    FiCompass,
    FiShield,
    FiCode
};

const services = frontmatter.services;
---

<section id="services" class="py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-4">
        
        <!-- Titre et description de la section -->
        <div class="max-w-2xl mb-14">
          <p class="font-mono text-xs text-primary mb-4">// mes compétences</p>
          <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
            Mon ADN technique
          </h2>
          <p class="text-muted-foreground mt-4 leading-relaxed">
            Ma valeur ajoutée se déploie sur trois axes complémentaires acquis
            et consolidés lors de mon cursus de Concepteur Développeur
            d'Applications (Bac+3).
          </p>
        </div>

        <!-- Cartes de services -->
        <div class="grid md:grid-cols-3 gap-5">
          {services.map((s: any) => {
            const IconComponent = iconMap[s.icon];
            return (
              <div class="surface-card rounded-2xl p-7 transition-colors hover:border-primary/40 group">
                <div class="flex items-center justify-between mb-6">
                  <div class="size-10 rounded-lg bg-primary/10 grid place-items-center text-primary group-hover:bg-primary/15 transition-colors">
                    <IconComponent size={18} />
                  </div>
                  <span class="font-mono text-xs text-muted-foreground">
                    {s.number}
                  </span>
                </div>
                <h3 class="text-lg font-semibold tracking-tight mb-3">
                  {s.title}
                </h3>
                <p class="text-sm text-muted-foreground leading-relaxed mb-6">
                  {s.description}
                </p>
                <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border/60">
                  {s.stack.map((t: string) => (
                    <span class="font-mono text-[10px] uppercase tracking-wider px-2 py-1 rounded-md bg-white/4 border border-white/5 text-muted-foreground">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            );
          })}
        </div>

      </div>
</section>